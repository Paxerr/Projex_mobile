<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ====== CONTENT SCREEN ====== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

    </LinearLayout>

    <!-- ====== OVERLAY MODAL (đặt SAU CÙNG) ====== -->
    <FrameLayout
        android:id="@+id/modalOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_overlay_dim"
        android:clickable="true"
        android:focusable="true"
        android:visibility="visible">

        <!-- Card -->
        <LinearLayout
            android:id="@+id/modalCard"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_card_white_radius"
            android:orientation="vertical"
            android:padding="14dp"
            android:elevation="10dp">

            <!-- Header: X - Title - Gửi -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="40dp">

                <ImageView
                    android:id="@+id/btnClose"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_close"
                    android:contentDescription="Đóng"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tvModalTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Thêm thành viên"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnSend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Gửi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A73E8"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tvMainTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Thêm người vào Jira"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <!-- Label + Input: Tên hoặc email -->
            <TextView
                android:id="@+id/tvLabelEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="TÊN HOẶC EMAIL"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#6B7280" />

            <EditText
                android:id="@+id/edtEmailOrName"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_stroke_round"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="Ví dụ: name@company.com"
                android:inputType="textEmailAddress"
                android:singleLine="true" />

            <!-- Label: SELECT ROLE -->
            <TextView
                android:id="@+id/tvLabelRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="SELECT ROLE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#6B7280" />

            <!-- Dropdown thuần: TextView + PopupMenu -->
            <RelativeLayout
                android:id="@+id/roleBox"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_stroke_round"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Member"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/icRoleChevron"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_chevron_down"
                    android:contentDescription="Mở danh sách" />
            </RelativeLayout>

            <!-- Footer: Hủy + Thêm -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="14dp">

                <TextView
                    android:id="@+id/btnCancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Hủy"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#6B7280"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnAdd"
                    android:layout_width="110dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_primary_button"
                    android:gravity="center"
                    android:text="Thêm"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </RelativeLayout>

        </LinearLayout>
    </FrameLayout>

</FrameLayout>