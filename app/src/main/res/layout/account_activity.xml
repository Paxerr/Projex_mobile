<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootAccount"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".AccountActivity"
    tools:deviceWidth="390dp"
    tools:deviceHeight="803dp">

    <TextView
        android:id="@+id/tvScreenTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="18dp"
        android:text="Trang tài khoản"
        android:textColor="#57A7FF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contentArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvScreenTitle">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="Back"
                android:src="@drawable/ic_back_24"
                android:tint="#FFFFFF"
                app:srcCompat="@drawable/ic_back" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tài khoản"
            android:textColor="#B9BDC8"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/btnBack" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnEditProfile"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="Edit profile"
                android:src="@drawable/ic_edit_24"
                android:tint="#4A8CFF"
                app:srcCompat="@drawable/account_ic_edit" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAvatar"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:layout_marginTop="22dp"
            app:cardBackgroundColor="#2A9EB9"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnBack">

            <TextView
                android:id="@+id/tvAvatarText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="TD"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <View
            android:id="@+id/viewOnlineDot"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/account_online_dot"
            app:layout_constraintBottom_toBottomOf="@+id/cardAvatar"
            app:layout_constraintEnd_toEndOf="@+id/cardAvatar" />

        <TextView
            android:id="@+id/tvFullName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Tiến Đạt Đinh"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardAvatar" />

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="dinhtiendat2105@gmail.com"
            android:textColor="#8C909A"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvFullName" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineStatsStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.0" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTasks"
            android:layout_width="0dp"
            android:layout_height="76dp"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="#17191F"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toStartOf="@+id/cardProjects"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvEmail"
            app:layout_constraintWidth_percent="0.31">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTasksValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="TASKS"
                    android:textColor="#6E778A"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProjects"
            android:layout_width="0dp"
            android:layout_height="76dp"
            app:cardBackgroundColor="#17191F"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/cardTasks"
            app:layout_constraintEnd_toStartOf="@+id/cardOnTime"
            app:layout_constraintStart_toEndOf="@+id/cardTasks"
            app:layout_constraintTop_toTopOf="@+id/cardTasks"
            app:layout_constraintWidth_percent="0.31">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvProjectsValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="PROJECTS"
                    android:textColor="#6E778A"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOnTime"
            android:layout_width="0dp"
            android:layout_height="76dp"
            app:cardBackgroundColor="#17191F"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/cardTasks"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/cardProjects"
            app:layout_constraintTop_toTopOf="@+id/cardTasks"
            app:layout_constraintWidth_percent="0.31">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvOnTimeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="98%"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="ON TIME"
                    android:textColor="#6E778A"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvSystemSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="CÀI ĐẶT HỆ THỐNG"
            android:textColor="#48505E"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.25"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardTasks" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNotifications"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="#17191F"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvSystemSettings">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/iconBellCard"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardBackgroundColor="#202A3C"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="Notification"
                        android:src="@drawable/ic_bell_24"
                        android:tint="#4A8CFF"
                        app:srcCompat="@drawable/account_ic_nofication" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvNotificationText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Thông báo đẩy"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/iconBellCard"
                    app:layout_constraintEnd_toStartOf="@+id/switchNotifications"
                    app:layout_constraintStart_toEndOf="@+id/iconBellCard"
                    app:layout_constraintTop_toTopOf="@+id/iconBellCard" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchNotifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:layout_constraintBottom_toBottomOf="@+id/iconBellCard"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/iconBellCard" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardChangePassword"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="#17191F"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardNotifications">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/iconLockCard"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardBackgroundColor="#1C2432"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="Lock"
                        android:src="@drawable/ic_lock_24"
                        android:tint="#FFFFFF"
                        app:srcCompat="@drawable/login_ic_lock" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvChangePassword"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Đổi mật khẩu"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/iconLockCard"
                    app:layout_constraintEnd_toStartOf="@+id/icChevronRight"
                    app:layout_constraintStart_toEndOf="@+id/iconLockCard"
                    app:layout_constraintTop_toTopOf="@+id/iconLockCard" />

                <ImageView
                    android:id="@+id/icChevronRight"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="Go"
                    android:src="@drawable/ic_chevron_right_24"
                    android:tint="#687085"
                    app:layout_constraintBottom_toBottomOf="@+id/iconLockCard"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/iconLockCard" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLogout"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="#170909"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardChangePassword"
            app:strokeColor="#311010"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="53dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/iconLogoutCard"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardBackgroundColor="#2B1212"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="Logout"
                        android:src="@drawable/ic_logout_24"
                        android:tint="#FF4D4D"
                        app:srcCompat="@drawable/account_logout" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvLogout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="ĐĂNG XUẤT"
                    android:textColor="#FF4D4D"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/iconLogoutCard"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/iconLogoutCard"
                    app:layout_constraintTop_toTopOf="@+id/iconLogoutCard" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavBar"
        android:layout_width="0dp"
        android:layout_height="76dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="#171A22"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bottomHome"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#171A22"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="Home"
                        android:src="@drawable/ic_home_24"
                        android:tint="#8A909B"
                        app:srcCompat="@drawable/account_ic_home" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="HOME"
                        android:textColor="#8A909B"
                        android:textSize="9sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bottomSpaces"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#171A22"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="Spaces"
                        android:src="@drawable/ic_spaces_24"
                        android:tint="#8A909B"
                        app:srcCompat="@drawable/ic_space" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="SPACES"
                        android:textColor="#8A909B"
                        android:textSize="9sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bottomTasks"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#171A22"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="Tasks"
                        android:src="@drawable/ic_tasks_24"
                        android:tint="#8A909B"
                        app:srcCompat="@drawable/ic_task" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="TASKS"
                        android:textColor="#8A909B"
                        android:textSize="9sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bottomNotification"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#171A22"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="Notification"
                        android:src="@drawable/ic_notification_24"
                        android:tint="#8A909B"
                        app:srcCompat="@drawable/ic_nofication" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="NOTIFICATION"
                        android:textColor="#8A909B"
                        android:textSize="9sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bottomUser"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#2A3B63"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="User"
                        android:src="@drawable/ic_user_24"
                        android:tint="#8CB2FF"
                        app:srcCompat="@drawable/ic_avatar" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="USER"
                        android:textColor="#8CB2FF"
                        android:textSize="9sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>