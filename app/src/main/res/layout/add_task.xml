
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#000000"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rjcpo7h0ekks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#000000"
        android:layout_marginTop="20dp"
        android:paddingVertical="18dp"
        android:paddingHorizontal="20dp"
        android:elevation="2dp">


        <Button
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hủy"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:backgroundTint="#000000"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>


        <Button
            android:id="@+id/btnCreate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tạo"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#000000"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>


        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tạo Task"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@id/btnCancel"
            app:layout_constraintEnd_toStartOf="@id/btnCreate"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
    <ScrollView
        android:id="@+id/r4m5g4fj9z98"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="#000000"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            >
            <LinearLayout
                android:id="@+id/rjepwwkqjlv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="117dp"
                android:orientation="vertical">
            <LinearLayout
                android:id="@+id/r4i8c6o0aiki"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp"
                android:layout_marginStart="20dp">

                <!-- GGshop -->
                <LinearLayout
                    android:id="@+id/rzp6jnle0w3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/pro_background"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="13dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="8dp"
                        android:src="@android:drawable/star_big_on"
                        />

                    <TextView
                        android:id="@+id/r2v6wmhftuqm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GGshop"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="9dp"
                        android:layout_height="5dp"
                        android:src="@android:drawable/star_big_on"
                        />
                </LinearLayout>

                <!-- Task -->
                <LinearLayout
                    android:id="@+id/ryzqa7ynojf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/pro_background"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="11dp"
                    android:layout_marginEnd="13dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_marginEnd="8dp"
                        android:src="@android:drawable/star_big_on"
                        />

                    <TextView
                        android:id="@+id/r7bwqu64a5bj"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Task"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="7dp"/>

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="9dp"
                        android:layout_height="5dp"
                        android:src="@android:drawable/star_big_on"
                        />
                </LinearLayout>

            </LinearLayout>
            <LinearLayout

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/pro_background"
                android:padding="8dp"
                android:layout_marginBottom="24dp"
                android:layout_marginHorizontal="20dp"
                android:elevation="24dp"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/taskname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Tên task"
                    android:textColorHint="#FFFFFF"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    />


            </LinearLayout>
            <LinearLayout

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/pro_background"
                android:padding="8dp"

                android:paddingHorizontal="16dp"
                android:layout_marginBottom="24dp"
                android:layout_marginHorizontal="20dp"
                android:elevation="24dp">

                <EditText
                    android:id="@+id/description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Description"
                    android:textColorHint="#FFFFFF"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"/>


            </LinearLayout>
            <LinearLayout

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/pro_background"
                    android:padding="8dp"

                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="24dp"
                    android:layout_marginHorizontal="20dp"
                    android:elevation="24dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/parent"
                        android:textColorHint="#FFFFFF"
                        android:textSize="18sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:hint="Parent"
                        android:layout_weight="1"
                        android:textColor="#FFFFFF"
                        />

                </LinearLayout>
                <LinearLayout
                    android:id="@+id/r4sjohnt3q2u"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/pro_background"
                    android:padding="8dp"

                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="24dp"
                    android:layout_marginHorizontal="20dp"
                    android:elevation="24dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/Duedate"
                        android:textColorHint="#FFFFFF"
                        android:textSize="18sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:hint="Due date"
                        android:layout_weight="1"
                        android:textColor="#FFFFFF"/>

                </LinearLayout>
                <LinearLayout

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/pro_background"
                    android:padding="8dp"

                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="24dp"
                    android:layout_marginHorizontal="20dp"
                    android:elevation="24dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/Startdate"
                        android:textColorHint="#FFFFFF"
                        android:textSize="18sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:hint="Start date"
                        android:layout_weight="1"
                        android:textColor="#FFFFFF"/>

                </LinearLayout>
                <LinearLayout

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/pro_background"
                    android:padding="8dp"

                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="24dp"
                    android:layout_marginHorizontal="20dp"
                    android:elevation="24dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/Priority"
                        android:textColorHint="#FFFFFF"
                        android:textSize="18sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:hint="Priority"
                        android:layout_weight="1"
                        android:inputType="number"
                        android:textColor="#FFFFFF"/>

                </LinearLayout>
            <LinearLayout
                android:id="@+id/attachment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/pro_background"
                android:padding="8dp"
                android:layout_marginHorizontal="20dp"
                android:elevation="12dp">

                <ImageView
                    android:id="@+id/rmsvxrrq5yr"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_attachment"
                    android:scaleType="fitXY" />

                <TextView
                    android:id="@+id/rfn0iowxe8w"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Tệp đính kèm"
                    android:textColorHint="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />



            </LinearLayout>
        </LinearLayout>

        </LinearLayout>

    </ScrollView>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/pro_background"
        android:paddingVertical="9dp"
        android:paddingHorizontal="5dp"

        app:layout_constraintBottom_toBottomOf="parent">

        <!-- HOME -->
        <LinearLayout
            android:id="@+id/btnHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnSpaces"
            app:layout_constraintTop_toTopOf="parent"
            >

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#737373"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- SPACES -->
        <LinearLayout
            android:id="@+id/btnSpaces"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"

            app:layout_constraintStart_toEndOf="@id/btnHome"
            app:layout_constraintEnd_toStartOf="@id/btnTasks"
            app:layout_constraintTop_toTopOf="parent"
            >

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_space"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPACES"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#737373"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- TASK -->
        <LinearLayout
            android:id="@+id/btnTasks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"

            app:layout_constraintStart_toEndOf="@id/btnSpaces"
            app:layout_constraintEnd_toStartOf="@id/btnNotify"
            app:layout_constraintTop_toTopOf="parent"
            >

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_task"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TASKS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#737373"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- NOTIFY -->
        <LinearLayout
            android:id="@+id/btnNotify"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"

            app:layout_constraintStart_toEndOf="@id/btnTasks"
            app:layout_constraintEnd_toStartOf="@id/btnUser"
            app:layout_constraintTop_toTopOf="parent"
            >

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_noti"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOTIFY"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#737373"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- USER -->
        <LinearLayout
            android:id="@+id/btnUser"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"

            app:layout_constraintStart_toEndOf="@id/btnNotify"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            >

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_user"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USER"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#737373"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>
